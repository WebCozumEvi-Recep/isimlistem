// İsim Listem — Networker aday takip + kişiye özel davet & davranış takip SaaS
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  UYE
  ADMIN
}

// Manuel huni durumu (mevcut — pano/liste bu sırayı kullanır)
enum SunumDurum {
  YENI // listeye eklendi, henüz aksiyon yok
  ARANDI // ilk iletişim kuruldu
  RANDEVU // randevu alındı
  SUNUM_YAPILDI // iş sunumu yapıldı
  TAKIP // takip aşamasında / düşünüyor
  KATILDI // ekibe katıldı (kazanım)
  KAYIP // ilgilenmedi / kapandı
}

enum KaynakTip {
  AILE
  AKRABA
  ARKADAS
  IS
  KOMSU
  OKUL
  SOSYAL_MEDYA
  REFERANS
  DIGER
}

enum AdayTipi {
  URUN_MUSTERISI
  IS_FIRSATI
  EKIP_ADAYI
  ESKI_MUSTERI
  TEKRAR_ARANACAK
  GENEL
}

enum Sicaklik {
  SOGUK
  ILIK
  SICAK
  COK_SICAK
}

enum SahiplikTipi {
  GLOBAL
  KISISEL
  FIRMA
}

enum SayfaDurum {
  TASLAK
  YAYINDA
  PASIF
}

enum LinkDurum {
  OLUSTURULDU
  GONDERILDI
  ACILDI
  ETKILESTI
  RANDEVU_ISTEDI
  ILGISIZ
}

enum ModulTip {
  KARSILAMA
  METIN
  GORSEL
  VIDEO
  BUTON
  RANDEVU
  SSS
  WHATSAPP
  YASAL
}

enum HazirMesajDurum {
  HAZIRLANDI
  WHATSAPP_ACILDI
  GONDERILDI_ONAY
  IPTAL
}

enum RandevuTip {
  TELEFON
  WHATSAPP
  ZOOM
  YUZ_YUZE
  OFIS
  DIGER
}

enum RandevuDurum {
  TALEP
  ONAYLANDI
  REDDEDILDI
  ERTELENDI
  TAMAMLANDI
  IPTAL
}

enum BildirimTip {
  LINK_ACILDI
  VIDEO_IZLEDI
  ILGILENIYOR
  RANDEVU
  WHATSAPP_DONUS
  TAKIP_ZAMANI
  ACILMAYAN_DAVET
}

model Kullanici {
  id            String         @id @default(cuid())
  adSoyad       String
  email         String         @unique
  telefon       String?
  parolaHash    String
  rol           Rol            @default(UYE)
  sehir         String?
  bio           String?
  profilFoto    String?
  kisiler       Kisi[]
  kaliplar      MesajKalibi[]
  sayfalar      DavetSayfasi[]
  bildirimler   Bildirim[]
  createdAt     DateTime       @default(now())
}

model Kisi {
  id           String       @id @default(cuid())
  adSoyad      String
  telefon      String?
  email        String?
  sehir        String?
  adayTipi     AdayTipi     @default(GENEL)
  sicaklik     Sicaklik     @default(ILIK)
  kaynakTip    KaynakTip    @default(DIGER)
  kaynakNot    String?
  durum        SunumDurum   @default(YENI)
  oncelik      Int          @default(0)
  notlar       String?
  skor         Int          @default(0)
  sonTemas     DateTime?
  sonrakiTakip DateTime?
  kullanici    Kullanici    @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId  String
  aktiviteler  Aktivite[]
  davetLinkleri DavetLinki[]
  hazirMesajlar HazirMesajLog[]
  randevular   RandevuTalebi[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([kullaniciId, durum])
  @@index([kullaniciId, sonrakiTakip])
}

model Aktivite {
  id       String     @id @default(cuid())
  kisi     Kisi       @relation(fields: [kisiId], references: [id], onDelete: Cascade)
  kisiId   String
  durum    SunumDurum
  aciklama String?
  otomatik Boolean    @default(false)
  tarih    DateTime   @default(now())
}

model MesajKalibi {
  id          String       @id @default(cuid())
  sahiplik    SahiplikTipi @default(KISISEL)
  kullanici   Kullanici?   @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String?
  baslik      String
  kategori    String       @default("ilk_temas")
  metin       String
  aktif       Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sahiplik])
  @@index([kullaniciId])
}

model DavetSayfasi {
  id          String        @id @default(cuid())
  sahiplik    SahiplikTipi  @default(KISISEL)
  kullanici   Kullanici?    @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String?
  baslik      String
  aciklama    String?
  amac        String        @default("is_firsati")
  durum       SayfaDurum    @default(TASLAK)
  varsayilan  Boolean       @default(false)
  moduller    DavetModulu[]
  linkler     DavetLinki[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([kullaniciId])
}

model DavetModulu {
  id        String       @id @default(cuid())
  sayfa     DavetSayfasi @relation(fields: [sayfaId], references: [id], onDelete: Cascade)
  sayfaId   String
  tip       ModulTip
  sira      Int          @default(0)
  icerik    Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([sayfaId, sira])
}

model DavetLinki {
  id           String        @id @default(cuid())
  token        String        @unique
  kisi         Kisi          @relation(fields: [kisiId], references: [id], onDelete: Cascade)
  kisiId       String
  kullaniciId  String
  sayfa        DavetSayfasi  @relation(fields: [sayfaId], references: [id], onDelete: Cascade)
  sayfaId      String
  durum        LinkDurum     @default(OLUSTURULDU)
  gonderildiAt DateTime?
  ilkAcilmaAt  DateTime?
  sonAcilmaAt  DateTime?
  acilmaSayisi Int           @default(0)
  olaylar      DavetOlayi[]
  randevular   RandevuTalebi[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([kullaniciId])
  @@index([kisiId])
}

model DavetOlayi {
  id          String     @id @default(cuid())
  link        DavetLinki @relation(fields: [linkId], references: [id], onDelete: Cascade)
  linkId      String
  kullaniciId String
  kisiId      String
  olayTip     String
  olayDeger   String?
  modulId     String?
  videoYuzde  Int?
  scrollYuzde Int?
  sayfadaSure Int?
  sessionId   String
  ipHash      String?
  uaHash      String?
  createdAt   DateTime   @default(now())

  @@index([linkId, sessionId])
  @@index([kisiId, olayTip])
}

model HazirMesajLog {
  id               String          @id @default(cuid())
  kullaniciId      String
  kisi             Kisi            @relation(fields: [kisiId], references: [id], onDelete: Cascade)
  kisiId           String
  kalipId          String?
  linkId           String?
  mesajMetni       String
  waMeUrl          String
  durum            HazirMesajDurum @default(HAZIRLANDI)
  gonderildiOnayAt DateTime?
  createdAt        DateTime        @default(now())

  @@index([kisiId])
}

model RandevuTalebi {
  id          String       @id @default(cuid())
  kullaniciId String
  kisi        Kisi         @relation(fields: [kisiId], references: [id], onDelete: Cascade)
  kisiId      String
  link        DavetLinki?  @relation(fields: [linkId], references: [id], onDelete: SetNull)
  linkId      String?
  tarihMetni  String?
  tip         RandevuTip   @default(WHATSAPP)
  mesaj       String?
  durum       RandevuDurum @default(TALEP)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([kullaniciId, durum])
}

model Bildirim {
  id          String      @id @default(cuid())
  kullanici   Kullanici   @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String
  baslik      String
  mesaj       String
  tip         BildirimTip
  kisiId      String?
  linkId      String?
  okundu      Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@index([kullaniciId, okundu])
}
