// İsim Listem — Networker aday takip + kişiye özel davet & davranış takip SaaS
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  UYE
  ADMIN
}

enum FirmaUyeRol {
  FIRMA_ADMIN
  ICERIK_YONETICI
  RAPOR_IZLEYICI
  NETWORKER
}

enum FirmaDurum {
  AKTIF
  PASIF
  ASKIDA
}

enum Paket {
  FREE
  BUSINESS
  BUSINESS_PLUS
}

// Manuel huni durumu (mevcut — pano/liste bu sırayı kullanır)
enum SunumDurum {
  YENI // listeye eklendi, henüz aksiyon yok
  ARANDI // ilk iletişim kuruldu
  RANDEVU // randevu alındı
  SUNUM_YAPILDI // iş sunumu yapıldı
  TAKIP // takip aşamasında / düşünüyor
  KATILDI // ekibe katıldı (kazanım)
  KAYIP // ilgilenmedi / kapandı
}

enum KaynakTip {
  AILE
  AKRABA
  ARKADAS
  IS
  KOMSU
  OKUL
  SOSYAL_MEDYA
  REFERANS
  DIGER
}

enum AdayTipi {
  URUN_MUSTERISI
  IS_FIRSATI
  EKIP_ADAYI
  LIDER
  ESKI_MUSTERI
  TEKRAR_ARANACAK
  GENEL
}

enum Sicaklik {
  SOGUK
  ILIK
  SICAK
  COK_SICAK
}

enum SahiplikTipi {
  GLOBAL
  KISISEL
  FIRMA
}

enum SayfaDurum {
  TASLAK
  YAYINDA
  PASIF
}

enum LinkDurum {
  OLUSTURULDU
  GONDERILDI
  ACILDI
  ETKILESTI
  RANDEVU_ISTEDI
  ILGISIZ
}

enum ModulTip {
  KARSILAMA
  METIN
  GORSEL
  VIDEO
  BUTON
  RANDEVU
  SSS
  WHATSAPP
  YASAL
  NEDENLER
  LISTE
  ADIMLAR
  HIKAYELER
  SECIM
}

enum HazirMesajDurum {
  HAZIRLANDI
  WHATSAPP_ACILDI
  GONDERILDI_ONAY
  IPTAL
}

enum RandevuTip {
  TELEFON
  WHATSAPP
  ZOOM
  YUZ_YUZE
  OFIS
  DIGER
}

enum RandevuDurum {
  TALEP
  ONAYLANDI
  REDDEDILDI
  ERTELENDI
  TAMAMLANDI
  IPTAL
}

enum BildirimTip {
  LINK_ACILDI
  VIDEO_IZLEDI
  ILGILENIYOR
  RANDEVU
  WHATSAPP_DONUS
  TAKIP_ZAMANI
  ACILMAYAN_DAVET
  YENI_ADAY
}

model Kullanici {
  id              String         @id @default(cuid())
  adSoyad         String
  email           String         @unique
  telefon         String?
  parolaHash      String
  rol             Rol            @default(UYE)
  sehir           String?
  bio             String?
  profilFoto      String?
  varsayilanFirmaId String?
  kisiler         Kisi[]
  kaliplar        MesajKalibi[]
  sayfalar        DavetSayfasi[]
  bildirimler     Bildirim[]
  pushTokenlar    PushToken[]
  parolaSifirlamalar ParolaSifirlama[]
  // Push bildirim tercihleri
  pushAcik        Boolean        @default(true) // ana anahtar
  pushTumu        Boolean        @default(false) // (kullanılmıyor — pushTipler ile değiştirildi)
  // Hangi bildirim tiplerinde push gönderilsin (BildirimTip değerleri)
  pushTipler      String[]       @default(["ILGILENIYOR", "RANDEVU", "WHATSAPP_DONUS", "YENI_ADAY", "TAKIP_ZAMANI"])
  pushSessizBas   Int?           @default(23) // sessiz saat başlangıcı (0-23), null = kapalı
  pushSessizBit   Int?           @default(8) // sessiz saat bitişi (0-23)
  firmaUyelikler  FirmaUye[]
  createdAt       DateTime       @default(now())
}

model Firma {
  id          String        @id @default(cuid())
  ad          String
  slug        String        @unique
  logoUrl     String?
  anaRenk     String?
  aciklama    String?
  website     String?
  telefon     String?
  whatsapp    String?
  footerMetni String?
  paket       Paket         @default(BUSINESS)
  durum       FirmaDurum    @default(AKTIF)
  kayitKodu   String        @unique
  networkerLimiti Int?
  uyeler      FirmaUye[]
  kaliplar    MesajKalibi[]
  sayfalar    DavetSayfasi[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model FirmaUye {
  id          String      @id @default(cuid())
  firma       Firma       @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId     String
  kullanici   Kullanici   @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String
  rol         FirmaUyeRol @default(NETWORKER)
  durum       FirmaDurum  @default(AKTIF)
  createdAt   DateTime    @default(now())

  @@unique([firmaId, kullaniciId])
  @@index([firmaId])
}

model Kisi {
  id           String       @id @default(cuid())
  adSoyad      String
  telefon      String?
  email        String?
  sehir        String?
  adayTipi     AdayTipi     @default(GENEL)
  sicaklik     Sicaklik     @default(ILIK)
  kaynakTip    KaynakTip    @default(DIGER)
  kaynakNot    String?
  durum        SunumDurum   @default(YENI)
  oncelik      Int          @default(0)
  notlar       String?
  skor         Int          @default(0)
  sonTemas     DateTime?
  sonrakiTakip DateTime?
  kullanici    Kullanici    @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId  String
  aktiviteler  Aktivite[]
  davetLinkleri DavetLinki[]
  hazirMesajlar HazirMesajLog[]
  randevular   RandevuTalebi[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([kullaniciId, durum])
  @@index([kullaniciId, sonrakiTakip])
}

model Aktivite {
  id       String     @id @default(cuid())
  kisi     Kisi       @relation(fields: [kisiId], references: [id], onDelete: Cascade)
  kisiId   String
  durum    SunumDurum
  aciklama String?
  otomatik Boolean    @default(false)
  tarih    DateTime   @default(now())
}

model MesajKalibi {
  id          String       @id @default(cuid())
  sahiplik    SahiplikTipi @default(KISISEL)
  kullanici   Kullanici?   @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String?
  firma       Firma?       @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId     String?
  baslik      String
  kategori    String       @default("ilk_temas")
  metin       String
  aktif       Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sahiplik])
  @@index([kullaniciId])
  @@index([firmaId])
}

model DavetSayfasi {
  id          String        @id @default(cuid())
  sahiplik    SahiplikTipi  @default(KISISEL)
  kullanici   Kullanici?    @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String?
  firma       Firma?        @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId     String?
  baslik      String
  aciklama    String?
  kapakGorsel String?
  amac        String        @default("is_firsati")
  durum       SayfaDurum    @default(TASLAK)
  varsayilan  Boolean       @default(false)
  moduller    DavetModulu[]
  linkler     DavetLinki[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([kullaniciId])
  @@index([firmaId])
}

model DavetModulu {
  id        String       @id @default(cuid())
  sayfa     DavetSayfasi @relation(fields: [sayfaId], references: [id], onDelete: Cascade)
  sayfaId   String
  tip       ModulTip
  sira      Int          @default(0)
  icerik    Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([sayfaId, sira])
}

model DavetLinki {
  id           String        @id @default(cuid())
  token        String        @unique
  kisi         Kisi          @relation(fields: [kisiId], references: [id], onDelete: Cascade)
  kisiId       String
  kullaniciId  String
  sayfa        DavetSayfasi  @relation(fields: [sayfaId], references: [id], onDelete: Cascade)
  sayfaId      String
  durum        LinkDurum     @default(OLUSTURULDU)
  gonderildiAt DateTime?
  ilkAcilmaAt  DateTime?
  sonAcilmaAt  DateTime?
  acilmaSayisi Int           @default(0)
  olaylar      DavetOlayi[]
  randevular   RandevuTalebi[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([kullaniciId])
  @@index([kisiId])
}

model DavetOlayi {
  id          String     @id @default(cuid())
  link        DavetLinki @relation(fields: [linkId], references: [id], onDelete: Cascade)
  linkId      String
  kullaniciId String
  kisiId      String
  olayTip     String
  olayDeger   String?
  modulId     String?
  videoYuzde  Int?
  scrollYuzde Int?
  sayfadaSure Int?
  sessionId   String
  ipHash      String?
  uaHash      String?
  createdAt   DateTime   @default(now())

  @@index([linkId, sessionId])
  @@index([kisiId, olayTip])
}

model HazirMesajLog {
  id               String          @id @default(cuid())
  kullaniciId      String
  kisi             Kisi            @relation(fields: [kisiId], references: [id], onDelete: Cascade)
  kisiId           String
  kalipId          String?
  linkId           String?
  mesajMetni       String
  waMeUrl          String
  durum            HazirMesajDurum @default(HAZIRLANDI)
  gonderildiOnayAt DateTime?
  createdAt        DateTime        @default(now())

  @@index([kisiId])
}

model RandevuTalebi {
  id          String       @id @default(cuid())
  kullaniciId String
  kisi        Kisi         @relation(fields: [kisiId], references: [id], onDelete: Cascade)
  kisiId      String
  link        DavetLinki?  @relation(fields: [linkId], references: [id], onDelete: SetNull)
  linkId      String?
  tarihMetni  String?
  tip         RandevuTip   @default(WHATSAPP)
  mesaj       String?
  sonucNotu   String?
  durum       RandevuDurum @default(TALEP)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([kullaniciId, durum])
}

enum TalepTipi {
  DEMO
  KURUMSAL
}

enum TalepDurum {
  YENI
  GORUSULDU
  ISTEMIYOR
  KURULUM_YAPILDI
}

model TalepFormu {
  id        String     @id @default(cuid())
  tip       TalepTipi  @default(DEMO)
  adSoyad   String
  firma     String?
  email     String
  telefon   String?
  mesaj     String?
  durum     TalepDurum @default(YENI)
  not       String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([durum, createdAt])
}

model SiteAyar {
  id              String   @id @default("default")
  siteAdi         String   @default("İsim Listem")
  slogan          String?
  logoUrl         String?
  logoBeyazUrl    String?  // koyu zeminler (e-posta başlığı vb.) için beyaz logo
  faviconUrl      String?
  aciklama        String?
  googleDogrulama String?
  analitikKodu    String?  // <head> içine eklenecek JS (GA/GTM/Pixel)
  destekEmail     String?  // İletişim bölümünde gösterilen / form bildirimlerinin gönderildiği e-posta
  // SMTP / e-posta gönderim ayarları (talep formu bildirimleri için)
  smtpHost        String?
  smtpPort        Int?
  smtpGuvenli     Boolean? @default(false) // true = 465 SSL, false = 587 STARTTLS
  smtpKullanici   String?
  smtpParola      String?
  smtpGonderenAd  String?  // "İsim Listem" gibi görünen ad
  smtpGonderen    String?  // gönderen e-posta adresi (from)
  // Sözleşme / yasal sayfa içerikleri (boşsa varsayılan metin kullanılır)
  kvkkMetni       String?
  gizlilikMetni   String?
  cerezMetni      String?
  kullanimMetni   String?
  mesafeliMetni   String?
  uyelikMetni     String?
  updatedAt       DateTime @updatedAt @default(now())
}

// Aday silindiğinde davet linkleri de silinir; eski token'la geri dönen kişinin
// kendini yeniden aday olarak ekleyebilmesi için bırakılan iz (tombstone).
// Parola sıfırlama e-postası ile gönderilen tek kullanımlık token.
model ParolaSifirlama {
  id          String    @id @default(cuid())
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String
  token       String    @unique
  sonKullanma DateTime
  createdAt   DateTime  @default(now())

  @@index([kullaniciId])
}

// Mobil uygulamanın push bildirim adresleri (Expo push token).
model PushToken {
  id          String    @id @default(cuid())
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String
  token       String    @unique
  platform    String? // ios | android
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([kullaniciId])
}

model SilinmisDavet {
  id          String   @id @default(cuid())
  token       String   @unique
  kullaniciId String // daveti gönderen (sahip)
  sayfaId     String
  eskiAdSoyad String?
  eskiTelefon String?
  createdAt   DateTime @default(now())

  @@index([kullaniciId])
}

model Bildirim {
  id          String      @id @default(cuid())
  kullanici   Kullanici   @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId String
  baslik      String
  mesaj       String
  tip         BildirimTip
  kisiId      String?
  linkId      String?
  okundu      Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@index([kullaniciId, okundu])
}
